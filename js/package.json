{
  "name": "videodubber",
  "version": "0.2.3",
  "description": "Official JS/TS SDK for VideoDubber.ai — AI video translation, audio dubbing & voice cloning API (150+ languages). Node 18+. Python client also on PyPI.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "videodubber": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "sync-version": "node scripts/sync-version.mjs",
    "build": "npm run sync-version && tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "videodubber",
    "videodubber.ai",
    "video",
    "video-translation",
    "translation",
    "dubbing",
    "ai-dubbing",
    "voice-cloning",
    "text-to-speech",
    "tts",
    "subtitle",
    "localization",
    "api",
    "api-client",
    "sdk",
    "nodejs",
    "typescript",
    "media",
    "multilingual"
  ],
  "author": "VideoDubber <contact@videodubber.ai>",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Souvic/VideoDubber.git",
    "directory": "js"
  },
  "bugs": {
    "url": "https://github.com/Souvic/VideoDubber/issues"
  },
  "homepage": "https://videodubber.ai/developers/",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3"
  }
}
